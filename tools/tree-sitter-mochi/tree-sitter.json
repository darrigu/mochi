{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "mochi",
      "camelcase": "Mochi",
      "title": "Mochi",
      "scope": "source.mochi",
      "file-types": [
        "moc"
      ],
      "injection-regex": "^mochi$",
      "class-name": "TreeSitterMochi"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Mochi grammar for tree-sitter",
    "authors": [
      {
        "name": "Hugo Darrieutort-Garcia",
        "email": "h.darrieutortg@gmail.com",
        "url": "https://github.com/darrigu"
      }
    ],
    "links": {
      "repository": "https://github.com/darrigu/mochi",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}